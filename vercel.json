{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "prisma generate && next build",
  "installCommand": "npm install",
  "framework": "nextjs",
  "functions": {
    "src/app/api/copilot/route.ts": { "maxDuration": 60 },
    "src/app/api/predictions/route.ts": { "maxDuration": 60 },
    "src/app/api/reports/route.ts": { "maxDuration": 60 },
    "src/app/api/weather/route.ts": { "maxDuration": 30 }
  }
}
