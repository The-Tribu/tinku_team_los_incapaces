// SunHub · Canonical data model
// See docs/ESPECIFICACIONES_TECNICAS.md §4 for rationale.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── Autenticación y usuarios ──────────────────────────────────
model User {
  id           String    @id @default(uuid()) @db.Uuid
  email        String    @unique
  name         String
  passwordHash String    @map("password_hash")
  role         String    @default("viewer") // admin | ops | viewer
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now()) @map("created_at")
  lastLoginAt  DateTime? @map("last_login_at")
  sessions     Session[]
  notificationPreference NotificationPreference?

  @@map("users")
}

model Session {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("sessions")
}

// ── Comercial ─────────────────────────────────────────────────
model Client {
  id           String    @id @default(uuid()) @db.Uuid
  name         String
  contactEmail String?   @map("contact_email")
  region       String?
  createdAt    DateTime  @default(now()) @map("created_at")
  plants       Plant[]
  reports      Report[]

  @@map("clients")
}

model Plant {
  id           String    @id @default(uuid()) @db.Uuid
  clientId     String    @map("client_id") @db.Uuid
  code         String    @unique
  name         String
  location     String?
  lat          Decimal?  @db.Decimal(10, 6)
  lng          Decimal?  @db.Decimal(10, 6)
  capacityKwp  Decimal?  @map("capacity_kwp") @db.Decimal(10, 2)
  contractType String?   @map("contract_type")
  contractEnd  DateTime? @map("contract_end") @db.Date
  createdAt    DateTime  @default(now()) @map("created_at")

  client       Client                  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  devices      Device[]
  contracts    Contract[]
  reports      Report[]
  policy       PlantAutomationPolicy?
  remediations Remediation[]

  @@index([clientId])
  @@map("plants")
}

// ── Proveedores e integración ─────────────────────────────────
model Provider {
  id          String   @id @default(uuid()) @db.Uuid
  slug        String   @unique // growatt | huawei | deye | hoymiles | srne | solarman
  displayName String   @map("display_name")
  authType    String?  @map("auth_type")
  pollingMin  Int      @default(5) @map("polling_min")
  enabled     Boolean  @default(true)
  devices     Device[]

  @@map("providers")
}

model Device {
  id            String    @id @default(uuid()) @db.Uuid
  plantId       String    @map("plant_id") @db.Uuid
  providerId    String    @map("provider_id") @db.Uuid
  externalId    String    @map("external_id")
  kind          String // inverter | microinverter | battery
  model         String?
  installedAt   DateTime? @map("installed_at") @db.Date
  currentStatus String    @default("offline") @map("current_status") // online|warning|offline|degraded
  lastSeenAt    DateTime? @map("last_seen_at")

  plant        Plant            @relation(fields: [plantId], references: [id], onDelete: Cascade)
  provider     Provider         @relation(fields: [providerId], references: [id])
  readings     Reading[]
  alarms       Alarm[]
  predictions  Prediction[]
  baselines    DeviceBaseline[]
  remediations Remediation[]

  @@unique([providerId, externalId])
  @@index([plantId])
  @@map("devices")
}

// ── Series de tiempo ──────────────────────────────────────────
model Reading {
  id           BigInt   @id @default(autoincrement())
  deviceId     String   @map("device_id") @db.Uuid
  ts           DateTime
  powerAcKw    Decimal? @map("power_ac_kw") @db.Decimal(10, 3)
  voltageV     Decimal? @map("voltage_v") @db.Decimal(10, 2)
  currentA     Decimal? @map("current_a") @db.Decimal(10, 2)
  frequencyHz  Decimal? @map("frequency_hz") @db.Decimal(6, 2)
  powerFactor  Decimal? @map("power_factor") @db.Decimal(4, 3)
  temperatureC Decimal? @map("temperature_c") @db.Decimal(5, 2)
  energyKwh    Decimal? @map("energy_kwh") @db.Decimal(12, 3)
  raw          Json?

  device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId, ts(sort: Desc)])
  @@map("readings")
}

// ── Contratos y compromisos ───────────────────────────────────
model Contract {
  id                String   @id @default(uuid()) @db.Uuid
  plantId           String   @map("plant_id") @db.Uuid
  periodMonth       DateTime @map("period_month") @db.Date
  targetEnergyKwh   Decimal? @map("target_energy_kwh") @db.Decimal(12, 2)
  targetSavingsCop  Decimal? @map("target_savings_cop") @db.Decimal(14, 2)
  targetUptimePct   Decimal? @map("target_uptime_pct") @db.Decimal(5, 2)
  targetPrPct       Decimal? @map("target_pr_pct") @db.Decimal(5, 2)
  targetCo2Ton      Decimal? @map("target_co2_ton") @db.Decimal(10, 3)
  penaltyPerBreach  Decimal? @map("penalty_per_breach") @db.Decimal(14, 2)

  plant Plant @relation(fields: [plantId], references: [id], onDelete: Cascade)

  @@unique([plantId, periodMonth])
  @@map("contracts")
}

// ── Alarmas y predicciones ────────────────────────────────────
model Alarm {
  id               String    @id @default(uuid()) @db.Uuid
  deviceId         String    @map("device_id") @db.Uuid
  severity         String // critical | warning | info
  type             String // offline | frequency | voltage | low_gen | temperature | provider
  source           String    @default("rule") @map("source") // rule | deye | growatt | huawei
  providerAlarmKey String?   @map("provider_alarm_key") // id nativo del proveedor cuando source != rule
  message          String
  startedAt        DateTime  @default(now()) @map("started_at")
  resolvedAt       DateTime? @map("resolved_at")
  acknowledgedAt   DateTime? @map("acknowledged_at")
  acknowledgedBy   String?   @map("acknowledged_by") @db.Uuid
  notifiedAt       DateTime? @map("notified_at") // última vez que salió fanout
  assignee         String?
  aiSuggestion     String?   @map("ai_suggestion")

  device       Device        @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  predictions  Prediction[]
  remediations Remediation[]

  @@unique([deviceId, source, providerAlarmKey], name: "alarms_device_source_key")
  @@index([deviceId, startedAt(sort: Desc)])
  @@index([resolvedAt])
  @@index([severity, startedAt(sort: Desc)])
  @@map("alarms")
}

// ── Notificaciones ────────────────────────────────────────────
model NotificationPreference {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @unique @map("user_id") @db.Uuid
  emailEnabled      Boolean  @default(true) @map("email_enabled")
  browserEnabled    Boolean  @default(true) @map("browser_enabled")
  soundEnabled      Boolean  @default(true) @map("sound_enabled")
  minSeverity       String   @default("warning") @map("min_severity") // critical | warning | info
  cooldownMinutes   Int      @default(10) @map("cooldown_minutes")
  updatedAt         DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

model NotificationLog {
  id        String   @id @default(uuid()) @db.Uuid
  alarmId   String   @map("alarm_id") @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  channel   String // email | browser | sse
  status    String // sent | skipped | failed
  detail    String?
  sentAt    DateTime @default(now()) @map("sent_at")

  @@index([alarmId, sentAt(sort: Desc)])
  @@index([userId, sentAt(sort: Desc)])
  @@map("notification_logs")
}

model Prediction {
  id              String   @id @default(uuid()) @db.Uuid
  deviceId        String   @map("device_id") @db.Uuid
  predictedType   String   @map("predicted_type") // failure | degradation | low_gen
  probability     Decimal  @db.Decimal(4, 3)
  daysToEvent     Decimal? @map("days_to_event") @db.Decimal(5, 2)
  confidence      Decimal? @db.Decimal(4, 3)
  rootCause       String?  @map("root_cause")
  suggestedAction String?  @map("suggested_action")
  modelVersion    String?  @map("model_version")
  generatedAt     DateTime @default(now()) @map("generated_at")
  // Origen de la predicción:
  //   scheduled → corrida manual o programada
  //   alarm     → disparada por una alarma nueva (ver sourceAlarmId)
  //   anomaly   → disparada por ruptura de baseline (z-score)
  triggerKind     String   @default("scheduled") @map("trigger_kind")
  sourceAlarmId   String?  @map("source_alarm_id") @db.Uuid

  device       Device              @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  sourceAlarm  Alarm?              @relation(fields: [sourceAlarmId], references: [id], onDelete: SetNull)
  outcome      PredictionOutcome?
  remediations Remediation[]

  @@index([deviceId, generatedAt(sort: Desc)])
  @@index([triggerKind, generatedAt(sort: Desc)])
  @@map("predictions")
}

// ── Aprendizaje continuo ──────────────────────────────────────
// Outcome de una predicción: ¿el evento ocurrió? lo cerramos manualmente o lo
// emparejamos con una alarma. Se consume luego como RAG en el prompt del LLM.
model PredictionOutcome {
  id              String    @id @default(uuid()) @db.Uuid
  predictionId    String    @unique @map("prediction_id") @db.Uuid
  status          String // confirmed | dismissed | auto_matched | expired
  matchedAlarmId  String?   @map("matched_alarm_id") @db.Uuid
  actualEventAt   DateTime? @map("actual_event_at")
  notes           String?
  decidedBy       String?   @map("decided_by") @db.Uuid
  decidedAt       DateTime  @default(now()) @map("decided_at")

  prediction Prediction @relation(fields: [predictionId], references: [id], onDelete: Cascade)

  @@index([status, decidedAt(sort: Desc)])
  @@map("prediction_outcomes")
}

// Baseline rolling por device+métrica. Se actualiza nightly y provee la media
// + stddev contra la que se calculan z-scores para anomalías proactivas.
model DeviceBaseline {
  id         String   @id @default(uuid()) @db.Uuid
  deviceId   String   @map("device_id") @db.Uuid
  metric     String // power_ac_kw | voltage_v | temperature_c | pr_pct | uptime_pct
  windowDays Int      @default(30) @map("window_days")
  sampleSize Int      @default(0) @map("sample_size")
  mean       Decimal  @db.Decimal(14, 4)
  stddev     Decimal  @db.Decimal(14, 4)
  p05        Decimal? @db.Decimal(14, 4)
  p50        Decimal? @db.Decimal(14, 4)
  p95        Decimal? @db.Decimal(14, 4)
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at")

  device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@unique([deviceId, metric, windowDays])
  @@index([metric])
  @@map("device_baselines")
}

// ── Automatización: política por planta + remediaciones ───────
// Controla si la operación puede ejecutar comandos automáticamente, con
// aprobación humana, o solo sugerirlos. executionMode decide si el executor
// envía el POST real al middleware o se queda en simulación.
model PlantAutomationPolicy {
  id                 String   @id @default(uuid()) @db.Uuid
  plantId            String   @unique @map("plant_id") @db.Uuid
  autonomyLevel      String   @default("manual") @map("autonomy_level") // manual | approval | auto
  executionMode      String   @default("mock") @map("execution_mode") // mock | real
  allowedCommands    String[] @default([]) @map("allowed_commands")
  requiredApproverRole String @default("admin") @map("required_approver_role") // admin | ops
  maxActionsPerDay   Int      @default(10) @map("max_actions_per_day")
  notes              String?
  updatedBy          String?  @map("updated_by") @db.Uuid
  updatedAt          DateTime @default(now()) @updatedAt @map("updated_at")

  plant Plant @relation(fields: [plantId], references: [id], onDelete: Cascade)

  @@map("plant_automation_policies")
}

// Propuesta de remediación. Atada opcionalmente a una predicción o alarma.
// lifecycle: proposed → (approved|rejected) → executed → (verified|failed).
// Cada intento de ejecución deja un registro en RemediationAudit.
model Remediation {
  id               String    @id @default(uuid()) @db.Uuid
  plantId          String    @map("plant_id") @db.Uuid
  deviceId         String?   @map("device_id") @db.Uuid
  predictionId     String?   @map("prediction_id") @db.Uuid
  alarmId          String?   @map("alarm_id") @db.Uuid
  commandType      String    @map("command_type") // restart | clear_fault | set_work_mode | custom_control
  commandPayload   Json      @map("command_payload")
  reason           String
  status           String    @default("proposed") // proposed | approved | rejected | executing | executed | verified | failed | cancelled
  executionMode    String    @default("mock") @map("execution_mode") // mock | real (decidido al ejecutar)
  proposedBy       String    @default("ai") @map("proposed_by") // ai | user
  proposedAt       DateTime  @default(now()) @map("proposed_at")
  approvedBy       String?   @map("approved_by") @db.Uuid
  approvedAt       DateTime? @map("approved_at")
  rejectedBy       String?   @map("rejected_by") @db.Uuid
  rejectedAt       DateTime? @map("rejected_at")
  rejectedReason   String?   @map("rejected_reason")
  executedAt       DateTime? @map("executed_at")
  executedBy       String?   @map("executed_by") @db.Uuid
  // orderId devuelto por el middleware cuando real mode tiene éxito (Deye).
  providerOrderId  String?   @map("provider_order_id")
  // Resumen breve del resultado (HTTP status, mensaje, simulado).
  executionResult  Json?     @map("execution_result")
  verifiedAt       DateTime? @map("verified_at")
  verifiedOutcome  String?   @map("verified_outcome") // success | partial | no_effect

  plant      Plant                @relation(fields: [plantId], references: [id], onDelete: Cascade)
  device     Device?              @relation(fields: [deviceId], references: [id], onDelete: SetNull)
  prediction Prediction?          @relation(fields: [predictionId], references: [id], onDelete: SetNull)
  alarm      Alarm?               @relation(fields: [alarmId], references: [id], onDelete: SetNull)
  audit      RemediationAudit[]

  @@index([plantId, proposedAt(sort: Desc)])
  @@index([status, proposedAt(sort: Desc)])
  @@map("remediations")
}

model RemediationAudit {
  id             String   @id @default(uuid()) @db.Uuid
  remediationId  String   @map("remediation_id") @db.Uuid
  event          String // proposed | approved | rejected | executed | verified | failed
  actorUserId    String?  @map("actor_user_id") @db.Uuid
  actorKind      String   @default("user") @map("actor_kind") // user | system | ai
  payload        Json?
  createdAt      DateTime @default(now()) @map("created_at")

  remediation Remediation @relation(fields: [remediationId], references: [id], onDelete: Cascade)

  @@index([remediationId, createdAt(sort: Desc)])
  @@map("remediation_audits")
}

// ── Reportes ──────────────────────────────────────────────────
model Report {
  id            String   @id @default(uuid()) @db.Uuid
  clientId      String   @map("client_id") @db.Uuid
  plantId       String?  @map("plant_id") @db.Uuid
  period        DateTime @db.Date
  status        String   @default("draft") // draft | generating | sent
  pdfUrl        String?  @map("pdf_url")
  compliancePct Decimal? @map("compliance_pct") @db.Decimal(5, 2)
  generatedAt   DateTime @default(now()) @map("generated_at")

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  plant  Plant? @relation(fields: [plantId], references: [id])

  @@index([clientId, period])
  @@map("reports")
}
