# ============================================================
# SunHub · Environment variables (template)
# ============================================================
# Copy to .env.local and fill with real values.
# .env.local is gitignored.
# ============================================================

# Middleware del Hackathon
MIDDLEWARE_BASE_URL=https://techos.thetribu.dev
MIDDLEWARE_API_KEY=tk_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# MiniMax (LLM para Copilot AI)
MINIMAX_API_KEY=sk-api-XXXXXXXXXXXXXXXXXXXXXXXX
MINIMAX_BASE_URL=https://api.minimax.io/v1
MINIMAX_MODEL=MiniMax-Text-01

# Weather API
WEATHER_BASE_URL=https://api.open-meteo.com/v1

# App
NEXT_PUBLIC_APP_NAME=SunHub
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Database
# DATABASE_URL → conexión usada por la app (pooler en prod, directa en local)
# DIRECT_URL   → conexión directa requerida por Prisma para migraciones
DATABASE_URL=postgresql://postgres:sunhub@localhost:5432/sunhub?schema=public
DIRECT_URL=postgresql://postgres:sunhub@localhost:5432/sunhub?schema=public
# REDIS_URL=redis://localhost:6379

# ── Auto-remediación ────────────────────────────────────────
# dry_run: el agente construye la petición pero NO la despacha (default seguro y
#          el modo recomendado mientras el middleware del hackathon no exponga
#          endpoints de escritura).
# shadow : despacha la petición pero marca outcome=no_change sin confiar en ella.
# live   : despacho completo + verificación automática a los 5 min.
REMEDIATION_MODE=dry_run
# 0 = sólo reglas deterministas · 1 = consulta MiniMax en casos ambiguos
# (requires_ai_decision=true en la policy). Umbral de confianza 0.7.
REMEDIATION_AI_AGENT=0
# Presupuesto (req/min) reservado para remediación dentro de los 60 req/min del
# middleware. El resto queda para ingest y consultas.
REMEDIATION_RATE_BUDGET=30
