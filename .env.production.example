# ============================================================
# SunHub · Production env template (Vercel + Neon/Supabase)
# ============================================================
# Copiar a la UI de Vercel (Project → Settings → Environment Variables)
# o a un gestor de secretos. NO COMMITTEAR con valores reales.
# ============================================================

# --- Middleware del Hackathon -------------------------------
MIDDLEWARE_BASE_URL=https://techos.thetribu.dev
MIDDLEWARE_API_KEY=tk_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# --- MiniMax (LLM Copilot) ----------------------------------
MINIMAX_API_KEY=sk-api-XXXXXXXXXXXXXXXXXXXXXXXX
MINIMAX_BASE_URL=https://api.minimax.io/v1
MINIMAX_MODEL=MiniMax-Text-01

# --- Weather (Open-Meteo, sin key) --------------------------
WEATHER_BASE_URL=https://api.open-meteo.com/v1

# --- App ----------------------------------------------------
NEXT_PUBLIC_APP_NAME=SunHub
NEXT_PUBLIC_APP_URL=https://sunhub.vercel.app
NODE_ENV=production

# --- Base de datos (Neon) -----------------------------------
# Usar el POOLED endpoint (-pooler) para el runtime — crucial en serverless
# para no saturar la DB con conexiones frías.
DATABASE_URL=postgresql://USER:PASSWORD@ep-XXXX-pooler.us-east-2.aws.neon.tech/sunhub?sslmode=require&pgbouncer=true&connect_timeout=10

# Endpoint DIRECTO (sin -pooler) — Prisma lo necesita para migrate/introspect
DIRECT_URL=postgresql://USER:PASSWORD@ep-XXXX.us-east-2.aws.neon.tech/sunhub?sslmode=require

# --- Base de datos (Supabase alternativa) -------------------
# DATABASE_URL=postgresql://postgres.PROJECT:PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true
# DIRECT_URL=postgresql://postgres.PROJECT:PASSWORD@aws-0-us-east-1.pooler.supabase.com:5432/postgres
