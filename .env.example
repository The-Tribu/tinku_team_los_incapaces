# ============================================================
# SunHub · Environment variables (template)
# ============================================================
# Copy to .env.local and fill with real values.
# .env.local is gitignored.
# ============================================================

# Middleware del Hackathon
MIDDLEWARE_BASE_URL=https://techos.thetribu.dev
MIDDLEWARE_API_KEY=tk_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# MiniMax (LLM para Copilot AI)
MINIMAX_API_KEY=sk-api-XXXXXXXXXXXXXXXXXXXXXXXX
MINIMAX_BASE_URL=https://api.minimax.io/v1
MINIMAX_MODEL=MiniMax-Text-01

# Weather API
WEATHER_BASE_URL=https://api.open-meteo.com/v1

# App
NEXT_PUBLIC_APP_NAME=SunHub
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ── DeyeCloud Demo (landing page + scraper) ──────────────────────────────────
# Intervalo real entre actualizaciones de la landing (ms). Default: 1000
# Valores sugeridos: 500 (rápido para demo) · 1000 (normal) · 2000 (lento)
NEXT_PUBLIC_DEYE_DEMO_TICK_MS=4000

# Segundos simulados que avanzan por cada tick. Default: 30
# Con TICK_MS=1000 y SIM_STEP_S=30 → 1 día solar completo en ~26 min reales
# Con TICK_MS=1000 y SIM_STEP_S=120 → 1 día solar en ~6.5 min (modo demo rápido)
# Con TICK_MS=1000 y SIM_STEP_S=1 → casi tiempo real (valores cambian lento)
NEXT_PUBLIC_DEYE_DEMO_SIM_STEP_S=30

# Intervalo del scraper entre ciclos de persistencia (ms). Default: 60000
# Independiente del tick de la landing — puede ser más lento o más rápido.
SCRAPE_INTERVAL_MS=60000

# URL base de la app Next.js que el scraper consultará
SCRAPE_BASE_URL=http://localhost:3000

# Database
# DATABASE_URL → conexión usada por la app (pooler en prod, directa en local)
# DIRECT_URL   → conexión directa requerida por Prisma para migraciones
DATABASE_URL=postgresql://postgres:sunhub@localhost:5432/sunhub?schema=public
DIRECT_URL=postgresql://postgres:sunhub@localhost:5432/sunhub?schema=public
# REDIS_URL=redis://localhost:6379

# Cron worker (sincronización con middleware)
CRON_INGEST_SCHEDULE=*/5 * * * *
CRON_ALARMS_SCHEDULE=* * * * *
CRON_PLANTS_SYNC_SCHEDULE=0 * * * *
CRON_TIMEZONE=America/Bogota
CRON_RUN_ON_START=1

# Alarm ingestion
# Ventana hacia atrás que el worker pide a cada provider por tick (días).
ALARMS_WINDOW_DAYS=2

# SMTP para notificaciones por email (dejar SMTP_HOST vacío para desactivar el canal)
# Local (default): Mailpit vía `make smtp-up` — captura correos en http://localhost:8025
#   SMTP_HOST=localhost · SMTP_PORT=1025 · sin auth
# Gmail: SMTP_HOST=smtp.gmail.com SMTP_PORT=465 + App Password
# Mailtrap: SMTP_HOST=sandbox.smtp.mailtrap.io SMTP_PORT=2525
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=SunHub <noreply@sunhub.local>
APP_BASE_URL=http://localhost:3000
